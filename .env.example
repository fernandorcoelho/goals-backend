# ---- Servidor ----
PORT=3000
# URL pública do backend (usada para montar os callbacks de OAuth)
BASE_URL=http://localhost:3000
# Para onde redirecionar o app/front após o login (o token vai na query ?token=).
# Deixe vazio para o callback responder em JSON.
FRONTEND_SUCCESS_URL=

# ---- Banco de dados (PostgreSQL) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/goals?schema=public"

# ---- JWT ----
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=7d

# ---- OAuth (preencha apenas os provedores que for usar) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple usa um client secret assinado (JWT) gerado a partir do Team ID, Key ID e
# da chave privada (.p8) baixada no Apple Developer. A chave privada vai inteira
# nesta variável (com as quebras de linha preservadas ou escapadas como \n).
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
