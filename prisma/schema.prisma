// Schema do banco de dados do app Goals.
// Modela: usuários com login social, perfil e a rotina semanal, onde as tarefas
// são cadastradas diretamente em cada dia da semana.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Provedores de login social suportados.
enum AuthProvider {
  GOOGLE
  FACEBOOK
  GITHUB
}

/// Dias da semana usados na rotina.
enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

/// Usuário do app. Não há cadastro: o usuário nasce do primeiro login social.
model User {
  id        String   @id @default(uuid())
  name      String
  nickname  String?  @unique
  photoUrl  String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  routine  Routine?

  @@map("users")
}

/// Vínculo entre um usuário e uma conta de um provedor OAuth.
/// Um mesmo usuário pode ter várias contas (ex.: Google + GitHub).
model Account {
  id                String       @id @default(uuid())
  provider          AuthProvider
  providerAccountId String
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())

  // Cada conta de provedor pertence a um único usuário.
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Rotina do usuário. Há no máximo uma rotina por usuário.
model Routine {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days RoutineDay[]

  @@map("routines")
}

/// Um dia da semana dentro da rotina, com as tarefas cadastradas nele.
model RoutineDay {
  id        String   @id @default(uuid())
  weekday   Weekday
  routineId String
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  // Cada dia da semana aparece no máximo uma vez por rotina.
  @@unique([routineId, weekday])
  @@map("routine_days")
}

/// Tarefa cadastrada diretamente em um dia da rotina (ex.: "Café da manhã").
model Task {
  id           String     @id @default(uuid())
  name         String
  completed    Boolean    @default(false)
  routineDayId String
  routineDay   RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([routineDayId])
  @@map("tasks")
}
